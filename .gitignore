# Build (Java/Maven)
target/
!.mvn/wrapper/maven-wrapper.jar
hs_err_pid*
replay_pid*

# Java artifacts — o Maven controla tudo em target/
*.class

# JARs gerados manualmente não precisam ser ignorados globalmente
# Removido: *.jar

# IDEs
.vscode/
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/

# Swap/Temp files
*.swp
*.swo

# Data files (da aplicação)
habit_tracker_data/
*.json

# OS-specific
.DS_Store
Thumbs.db

# Maven (não ignore a pasta ~/.m2 — ela não pertence ao repositório)
dependency-reduced-pom.xml

# Logs da execução personalizada
run_last.log
